{
  "$schema": "https://design-tokens.org/schema.json",
  "meta": {
    "brand": "BaytyAI",
    "version": "0.1.0",
    "note": "Portable source of truth. tokens.css is generated from these. Components consume semantic tokens only."
  },
  "reference": {
    "color": {
      "navy": { "900": "#060e1c", "800": "#0a1628", "700": "#0f1e35", "600": "#16294a" },
      "slate": { "700": "#2c3e50", "500": "#4a5b6b" },
      "gold": { "600": "#b8963f", "500": "#c9a84c", "300": "#e0c987" },
      "offwhite": "#f8f6f1",
      "white": "#ffffff",
      "emerald": { "800": "#0c2a24", "700": "#123a31" }
    },
    "state": { "ok": "#2f7a5b", "pending": "#c9a84c", "blocked": "#9b2c2c", "info": "#3a6ea5" },
    "viz": ["#c9a84c", "#3a6ea5", "#2f7a5b", "#8c6fb0", "#c87852", "#5b8a9c"]
  },
  "scale": {
    "radius": { "none": "0px", "subtle": "2px" },
    "border": { "hairline": "0.5px" },
    "space": { "section": "120px", "component": "64px" },
    "maxWidth": { "content": "1200px" },
    "duration": { "fast": "200ms", "base": "600ms" },
    "ease": "cubic-bezier(0.22, 1, 0.36, 1)",
    "font": {
      "display": "Cormorant Garamond",
      "body": "DM Sans",
      "mono": "DM Mono"
    }
  },
  "themes": {
    "light": {
      "bg": "{reference.color.offwhite}",
      "surface": "{reference.color.white}",
      "text": "{reference.color.navy.800}",
      "textMuted": "rgba(10,22,40,0.65)",
      "accent": "{reference.color.gold.500}",
      "onAccent": "{reference.color.navy.800}",
      "border": "rgba(10,22,40,0.12)",
      "focusRing": "{reference.color.gold.600}"
    },
    "dark": {
      "bg": "{reference.color.navy.800}",
      "surface": "{reference.color.navy.700}",
      "text": "{reference.color.offwhite}",
      "textMuted": "rgba(248,246,241,0.65)",
      "accent": "{reference.color.gold.500}",
      "onAccent": "{reference.color.navy.800}",
      "border": "rgba(201,168,76,0.2)",
      "focusRing": "{reference.color.gold.300}"
    },
    "sovereign": {
      "bg": "{reference.color.navy.900}",
      "surface": "{reference.color.emerald.800}",
      "text": "{reference.color.offwhite}",
      "textMuted": "rgba(248,246,241,0.7)",
      "accent": "{reference.color.gold.300}",
      "onAccent": "{reference.color.navy.900}",
      "border": "rgba(224,201,135,0.18)",
      "focusRing": "{reference.color.gold.300}"
    }
  }
}
