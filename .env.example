# ─── NextAuth (Auth.js) ───
# Generate a secret with:  npx auth secret    (or: openssl rand -base64 32)
AUTH_SECRET=

# ─── LinkedIn OAuth ───
# Create an app at https://www.linkedin.com/developers/apps
# Add the "Sign In with LinkedIn using OpenID Connect" product.
# Authorized redirect URL (use the www host — the apex redirects to it):
#   https://www.baytyai.com/api/auth/callback/linkedin
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# Canonical host — must be the www version since baytyai.com 308-redirects to www
AUTH_URL=https://www.baytyai.com

# ─── Lead capture (request-access + contact forms) ───
# Resend API key — create at https://resend.com (verify the baytyai.com domain first)
RESEND_API_KEY=
# Where form submissions are emailed (defaults to info@baytyai.com)
LEAD_TO_EMAIL=info@baytyai.com
# Verified sender on your Resend domain
LEAD_FROM_EMAIL=Bayty <noreply@baytyai.com>

# ─── Analytics (GA4) ───
# Google Analytics 4 Measurement ID (G-XXXXXXXXXX). Loads only after cookie consent.
NEXT_PUBLIC_GA_ID=

# ─── Supabase (email-OTP auth, admin roles, structured CMS) ───
# From Supabase project settings → API. Run supabase/schema.sql once after creating the project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY, never exposed to the browser. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=
