# ─── NextAuth (Auth.js) ───
# Generate a secret with:  npx auth secret    (or: openssl rand -base64 32)
AUTH_SECRET=

# ─── LinkedIn OAuth ───
# Create an app at https://www.linkedin.com/developers/apps
# Add the "Sign In with LinkedIn using OpenID Connect" product.
# Authorized redirect URL: https://baytyai.com/api/auth/callback/linkedin
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# Required in production so callbacks use the correct host
AUTH_URL=https://baytyai.com
