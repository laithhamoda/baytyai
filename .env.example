# ─── Canonical site URL (MUST be set in Vercel production — never use VERCEL_URL) ───
NEXT_PUBLIC_SITE_URL=https://www.baytyai.com

# ─── NextAuth (Auth.js) ───
# Generate with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=
# Canonical host — must be the www version since baytyai.com 308-redirects to it.
AUTH_URL=https://www.baytyai.com

# ─── Supabase (email-OTP auth, CMS, project intake database) ───
# From Supabase: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Email (Resend) ───
# Create at https://resend.com — verify the baytyai.com domain first.
RESEND_API_KEY=
# Marketing / lead capture emails
LEAD_TO_EMAIL=info@baytyai.com
LEAD_FROM_EMAIL=Bayty <noreply@baytyai.com>
# Dashboard / project intake emails
DASHBOARD_FROM_EMAIL=Bayty Projects <projects@baytyai.com>
DASHBOARD_OPS_EMAIL=ops@baytyai.com

# ─── Rate limiting (Upstash Redis) ───
# From Upstash: Console → Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Analytics (GA4) ───
NEXT_PUBLIC_GA_ID=
