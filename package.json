    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:impersonation": "node --env-file=.env.local node_modules/.bin/tsx scripts/seed-impersonation-users.ts"
